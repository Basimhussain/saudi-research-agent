# ---- LLM ----
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-4o

# ---- Memory backend ----
# sqlite (default, local dev) or postgres (deployment)
DB_TYPE=sqlite
DB_PATH=./agent_memory.db

# ---- Postgres (when DB_TYPE=postgres) ----
DATABASE_URL=postgresql://agent:agent@localhost:5432/saudi_agent
DB_POOL_MIN=1
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT=5
DB_STATEMENT_TIMEOUT_MS=30000
DB_RETRY_ATTEMPTS=5
DB_RETRY_BASE_DELAY=0.5
# prefer | require | verify-ca | verify-full | disable
DB_SSLMODE=prefer
DB_APPLICATION_NAME=saudi-research-agent

# ---- docker-compose overrides ----
POSTGRES_DB=saudi_agent
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_PORT=5432
